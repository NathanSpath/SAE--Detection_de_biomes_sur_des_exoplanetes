# ==========================================
# Fichiers Java compilés
# ==========================================
*.class

# Journaux d'erreurs générés par la JVM
hs_err_pid*
replay_pid*

# ==========================================
# Fichiers d'archives
# ==========================================
# (Décommente si tu as besoin de versionner certains .jar spécifiques)
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ==========================================
# Outils de Build
# ==========================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Éviter d'ignorer le wrapper Maven (recommandé)
!/.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
# Éviter d'ignorer le wrapper Gradle (recommandé)
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

